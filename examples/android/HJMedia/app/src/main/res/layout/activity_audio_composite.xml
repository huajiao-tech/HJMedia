<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cbCompositeEnableMixing"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="@string/audio_composite_enable_mixing" />

            <CheckBox
                android:id="@+id/cbCompositeMute"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/audio_composite_mute" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositeInit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_init" />

            <Button
                android:id="@+id/btnCompositeRelease"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_release" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCompositeMixMicRatio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositeMixMicRatio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositeRecordBegin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_record_begin" />

            <Button
                android:id="@+id/btnCompositeRecordEnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_record_end" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/audio_composite_player0_title"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCompositePlayer0Url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/audio_composite_player_url_hint"
            android:inputType="textUri"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositePlayer0Open"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player0_open" />

            <Button
                android:id="@+id/btnCompositePlayer0Close"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player0_close" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositePlayer0Pause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player_pause" />

            <Button
                android:id="@+id/btnCompositePlayer0Resume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player_resume" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCompositePlayer0Volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer0Volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer0MixVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer0MixVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer0Time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/audio_composite_time_default"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer0Progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer0Tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/audio_composite_tracks_default"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rgCompositePlayer0Tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCompositePlayer0Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/audio_composite_status_default"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/audio_composite_player1_title"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etCompositePlayer1Url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/audio_composite_player_url_hint"
            android:inputType="textUri"
            android:singleLine="true" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositePlayer1Open"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player1_open" />

            <Button
                android:id="@+id/btnCompositePlayer1Close"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player1_close" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCompositePlayer1Pause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player_pause" />

            <Button
                android:id="@+id/btnCompositePlayer1Resume"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/audio_composite_player_resume" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCompositePlayer1Volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer1Volume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer1MixVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer1MixVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer1Time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/audio_composite_time_default"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekCompositePlayer1Progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvCompositePlayer1Tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/audio_composite_tracks_default"
            android:textSize="13sp" />

        <RadioGroup
            android:id="@+id/rgCompositePlayer1Tracks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCompositePlayer1Status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/audio_composite_status_default"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvCompositeStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/audio_composite_status_default"
            android:textSize="13sp" />

    </LinearLayout>

</ScrollView>
